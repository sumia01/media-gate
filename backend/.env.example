# Media Gate configuration
# Copy this to .env and adjust values as needed.
# Environment variables with MEDIAGATE_ prefix override these values.
# Example: API_PORT here = MEDIAGATE_API_PORT as env var.

# HTTP server port
API_PORT=8080

# Trust X-Forwarded-For / X-Real-IP for client-IP derivation (login rate-limit).
# Enable ONLY when running behind a trusted reverse proxy that sets these headers;
# otherwise clients could spoof them to evade rate limiting. Default: false.
#API_TRUSTPROXY=false

# SQLite database path
DB_PATH=media-gate.db

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: text, json
LOG_FORMAT=text

# Base path for library directories (libraries must be within this path)
LIBRARY_BASEPATH=/mnt

# TMDB API key (optional — used as fallback when not set in the UI)
#TMDB_APIKEY=

# TVDB API key (optional — used as fallback when not set in the UI)
#TVDB_APIKEY=

# Master key for encrypting secrets at rest (required — also used for JWT signing)
#SECRET_KEY=

# Default user credentials (used only to create the initial user when DB has no users)
#DEFAULTUSER_EMAIL=admin@example.com
#DEFAULTUSER_PASSWORD=changeme

# Set to true when behind a TLS-terminating reverse proxy (ensures Secure flag on cookies)
#COOKIE_SECURE=false
