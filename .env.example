# Media Gate configuration
# Copy this to .env and adjust values as needed.
# Environment variables with MEDIAGATE_ prefix override these values.
# Example: API_PORT here = MEDIAGATE_API_PORT as env var.

# HTTP server port
API_PORT=8080

# SQLite database path
DB_PATH=media-gate.db

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: text, json
LOG_FORMAT=text

# Base path for library directories (libraries must be within this path)
LIBRARY_BASEPATH=/mnt

# TMDB API key (optional — used as fallback when not set in the UI)
#TMDB_APIKEY=

# TVDB API key (optional — used as fallback when not set in the UI)
#TVDB_APIKEY=

# Master key for encrypting secrets at rest (leave empty for plaintext dev mode)
#SECRET_KEY=
